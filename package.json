{
  "name": "yemot-system",
  "version": "1.0.0",
  "description": "מערכת הזמנות טלפונית עם אינטגרציה ל-Yemot Hamashiach",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd src/admin && npm run build",
    "build:server": "babel src --out-dir dist",
    "migrate": "node database/migrate.js",
    "seed": "node database/seed.js",
    "test:yemot": "node test-yemot.js",
    "test:connection": "node test-basic-connection.js",
    "build:ivr": "node build-yemot-ivr.js",
    "verify:yemot": "node verify-yemot-extensions.js"
  },
  "keywords": [
    "ivr",
    "ordering",
    "yemot",
    "hebrew"
  ],
  "author": "Yemot System Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "winston": "^3.11.0",
    "yemot-api": "^1.0.3",
    "yemot-router2": "^6.2.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.4",
    "@babel/preset-env": "^7.23.4",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.40.1",
    "supertest": "^6.3.3"
  }
}
