{
  "version": 2,
  "installCommand": "npm ci --omit=dev",
  "buildCommand": "echo Skipping repository build for api-link deployment",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/internal/process-transcriptions",
      "schedule": "0 6 * * *"
    }
  ]
}
